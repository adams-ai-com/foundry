# Foundry self-host configuration. Copy to .env and edit.

# Postgres password (used by all app databases). CHANGE THIS.
POSTGRES_PASSWORD=change-me-to-a-strong-secret

# Public domain. Leave blank for local eval (serves plain HTTP on :80).
# Set to your domain (e.g. foundry.example.com) and Caddy gets a TLS cert automatically.
FOUNDRY_DOMAIN=

# Host ports for the reverse proxy.
HTTP_PORT=80
HTTPS_PORT=443

# PDF processing service shared secret. CHANGE THIS.
PDF_PROC_SECRET=change-me-to-a-strong-secret

# Mail server API key (shared between mailserver and mail app). CHANGE THIS.
MAIL_API_KEY=change-me-to-a-strong-secret
# Default From address shown in the mail UI.
MAIL_FROM=foundry@localhost
