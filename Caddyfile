# Foundry self-host reverse proxy — single domain, path-routed per app.
# Apps under a subpath keep their basePath prefix (no stripping).
# FOUNDRY_DOMAIN: e.g. foundry.example.com (TLS auto); default :80 for local eval.
{$FOUNDRY_DOMAIN} {
	# Send unauthenticated visitors of a sub-app straight to the root login.
	# (Sub-apps have a Next basePath, so they can't redirect cross-app themselves.)
	@gated_unauth {
		path /wiki* /pdf* /mail*
		not header Cookie *foundry_session=*
	}
	redir @gated_unauth /login 302

	@wiki path /wiki /wiki/*
	handle @wiki {
		reverse_proxy wiki:3000
	}
	@pdf path /pdf /pdf/*
	handle @pdf {
		reverse_proxy pdf:3000
	}
	@mail path /mail /mail/*
	handle @mail {
		reverse_proxy mail:3000
	}
	handle {
		reverse_proxy workspace:3000
	}
}
