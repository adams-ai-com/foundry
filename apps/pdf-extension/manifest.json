{
  "manifest_version": 3,
  "name": "Foundry PDF",
  "version": "1.0.0",
  "description": "Edit any PDF in Foundry — right-click a PDF link or click Edit when viewing one.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Foundry PDF",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": [
    "<all_urls>",
    "https://foundry.adams-ai.com/*"
  ]
}
