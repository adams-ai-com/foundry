#!/bin/bash
# foundry-deploy — THE deploy entrypoint for every Foundry app on this server.
# Builds the app, restarts its service, then runs the FULL e2e gate
# (e2e-suite across all apps + the PDF deep suite). A deploy is not done
# until both suites are green.
#
# Usage: foundry-deploy <app> [--skip-build]
# Apps:  workspace docs sheets mail mailserver wiki channels sites pdf pdf-proc
#
# Canonical copy: /var/www/foundry/scripts/foundry-deploy (git-tracked).
# Installed copy: /usr/local/bin/foundry-deploy
# Log: /var/log/foundry-deploy.log
set -uo pipefail

APP=${1:?usage: foundry-deploy <app> [--skip-build]}
SKIP_BUILD=${2:-}
LOG=/var/log/foundry-deploy.log
MONOREPO=/var/www/foundry

log() { printf '%s %s\n' "$(date -u +%FT%TZ)" "$*" | tee -a "$LOG"; }

case "$APP" in
  workspace)  echo "workspace is on Coolify now — deploy by pushing to gitea (staging->staging, main->production)" >&2; exit 2 ;;
  docs)       echo "docs is on Coolify now — deploy by pushing to gitea (staging branch -> staging, main -> production)" >&2; exit 2 ;;
  sheets)       echo "sheets is on Coolify now — deploy by pushing to gitea (staging branch -> staging, main -> production)" >&2; exit 2 ;;
  mail)       echo "mail is on Coolify now — deploy by pushing to gitea (staging branch -> staging, main -> production)" >&2; exit 2 ;;
  mailserver) PKG=@foundry/mailserver SVC=foundry-mail ;;
  wiki)       echo "wiki is on Coolify now — deploy by pushing to gitea (staging branch -> staging, main -> production)" >&2; exit 2 ;;
  channels)       echo "channels is on Coolify now — deploy by pushing to gitea (staging branch -> staging, main -> production)" >&2; exit 2 ;;
  sites)       echo "sites is on Coolify now — deploy by pushing to gitea (staging branch -> staging, main -> production)" >&2; exit 2 ;;
  pdf)        echo "pdf is on Coolify now — deploy by pushing to gitea. NOTE: foundry-pdf-proc (Python sidecar) stays systemd." >&2; exit 2 ;;
  pdf-proc)   PKG=""                  SVC=foundry-pdf-proc ;;
  *) echo "unknown app: $APP" >&2; exit 2 ;;
esac

if [ "$(id -u)" != 0 ]; then
  echo "foundry-deploy must run as root (systemctl restart)" >&2
  exit 2
fi

log "=== deploy $APP start (pkg=${PKG:-none} svc=$SVC) ==="

if [ -n "$PKG" ] && [ "$SKIP_BUILD" != "--skip-build" ]; then
  log "building $PKG"
  if ! sudo -u foundry bash -c "export HOME=/home/foundry; cd $MONOREPO && pnpm --filter $PKG build" >>"$LOG" 2>&1; then
    log "BUILD FAILED — service NOT restarted, previous version still serving. See $LOG"
    exit 1
  fi
fi

log "restarting $SVC"
systemctl restart "$SVC"
sleep 6
if ! systemctl is-active --quiet "$SVC"; then
  log "SERVICE FAILED TO START — journalctl -u $SVC -n 50"
  exit 1
fi

run_suite() {
  local dir=$1 label=$2
  log "running $label"
  if sudo -u foundry bash -c "export HOME=/home/foundry; cd $dir && ./node_modules/.bin/playwright test --reporter=line" >>"$LOG" 2>&1; then
    log "$label PASSED"
    return 0
  fi
  log "$label FAILED — deploy is LIVE but did not verify. Inspect $dir/test-results/ and $LOG"
  return 1
}

FAIL=0
run_suite "$MONOREPO/e2e-suite" "e2e-suite (all apps)" || FAIL=1
run_suite "$MONOREPO/apps/pdf" "pdf deep suite" || FAIL=1

if [ "$FAIL" = 1 ]; then
  log "=== deploy $APP FAILED VERIFICATION — fix or roll back before walking away ==="
  exit 1
fi
log "=== deploy $APP OK — all tests green ==="
