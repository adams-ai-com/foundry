#!/bin/bash
# foundry-promote — staging → production promotion gate for the Foundry suite.
#
# Runs from a systemd timer (every minute). Flow per new commit on the gitea
# `staging` branch:
#   1. wait until affected apps' STAGING containers run that commit
#      (Coolify tags container images with the commit SHA; unaffected apps skip)
#   2. run the staging test suite for affected apps only
#   3. GREEN  -> fast-forward push the commit to `main` (Coolify then
#               auto-deploys production via its webhook)
#      RED    -> production does not move; status file records the block
#
# Each staging SHA is processed exactly once (state in /var/lib/foundry-promote).
# A red run is NOT retried automatically — push a fix to staging instead.
# Fast-forward-only push: this script can never rewrite main history.
#
# Converted apps are listed in /etc/foundry-promote/staging-apps
# (lines: <coolify-app-uuid> <label>). Update it as apps convert.
#
# Canonical copy: /var/www/foundry/scripts/foundry-promote (git-tracked).
set -uo pipefail

REPO=/var/www/foundry
STATE_DIR=/var/lib/foundry-promote
APPS_FILE=/etc/foundry-promote/staging-apps
LOG=/var/log/foundry-promote.log
DEPLOY_WAIT_SECS=${DEPLOY_WAIT_SECS:-2400}

log() { printf '%s %s\n' "$(date -u +%FT%TZ)" "$*" | tee -a "$LOG"; }
as_foundry() { sudo -u foundry env HOME=/home/foundry "$@"; }

exec 9>/var/lock/foundry-promote.lock
flock -n 9 || exit 0
mkdir -p "$STATE_DIR"

TARGET=$(as_foundry git -C "$REPO" ls-remote gitea refs/heads/staging 2>/dev/null | awk '{print $1}')
MAIN=$(as_foundry git -C "$REPO" ls-remote gitea refs/heads/main 2>/dev/null | awk '{print $1}')
if [ -z "$TARGET" ] || [ -z "$MAIN" ]; then
  log "cannot read branch SHAs from gitea — skipping cycle"
  exit 1
fi

if [ "$TARGET" = "$MAIN" ]; then
  echo "$TARGET" > "$STATE_DIR/last-processed"
  exit 0   # nothing to promote
fi

LAST=$(cat "$STATE_DIR/last-processed" 2>/dev/null || true)
if [ "$TARGET" = "$LAST" ]; then
  exit 0   # already handled (promoted or blocked) — new pushes re-trigger
fi

log "=== new staging commit $TARGET (main at ${MAIN:0:12}) ==="

# Fetch gitea early so we can compute the diff and determine affected apps.
as_foundry git -C "$REPO" fetch gitea >>"$LOG" 2>&1 || log "WARN: git fetch gitea failed — treating all apps as affected"

# Files changed between main and this staging commit.
CHANGED=$(as_foundry git -C "$REPO" diff --name-only "gitea/main" "gitea/staging" 2>/dev/null || true)

# Per-app watch paths: label -> colon-separated directory prefixes.
# An app is "affected" if any changed file starts with one of its prefixes,
# OR if its packages/ prefix is changed (shared libs), OR if CHANGED is empty
# (fallback: can't determine diff → treat all as affected).
declare -A WATCH_PATHS
WATCH_PATHS["pdf-staging"]="apps/pdf:packages:services/pdf-proc"
WATCH_PATHS["sheets-staging"]="apps/sheets:packages"
WATCH_PATHS["wiki-staging"]="apps/wiki:packages"
WATCH_PATHS["docs-staging"]="apps/docs:packages"
WATCH_PATHS["mail-staging"]="apps/mail:packages:services/mailserver"
WATCH_PATHS["channels-staging"]="apps/channels:packages"
WATCH_PATHS["sites-staging"]="apps/sites:packages"
WATCH_PATHS["workspace-staging"]="apps/workspace:packages"

# e2e spec file for each staging app (empty = no gate spec; build success is enough)
declare -A SPEC_FOR
SPEC_FOR["wiki-staging"]="specs/wiki.spec.ts"
SPEC_FOR["docs-staging"]="specs/docs.spec.ts"
SPEC_FOR["sheets-staging"]="specs/sheets.spec.ts"
SPEC_FOR["mail-staging"]="specs/mail.spec.ts"
SPEC_FOR["channels-staging"]="specs/channels.spec.ts"
SPEC_FOR["sites-staging"]="specs/sites.spec.ts"
SPEC_FOR["workspace-staging"]="specs/workspace.spec.ts"
# pdf-staging has no gate spec (deep suite lives in apps/pdf/e2e/)

is_affected() {
  local label="$1"
  # Normalize: strip -staging or -production suffix to look up WATCH_PATHS
  local base="${label%-staging}"; base="${base%-production}"
  local paths="${WATCH_PATHS[${base}-staging]:-}"
  # Unknown label or no watch config → always affected (safe fallback)
  [ -z "$paths" ] && return 0
  # Can't get diff → treat all as affected
  [ -z "$CHANGED" ] && return 0
  local IFS=':'
  for prefix in $paths; do
    if echo "$CHANGED" | grep -q "^${prefix}"; then
      return 0
    fi
  done
  return 1
}

# 1. Wait until affected staging apps run TARGET (unaffected apps are skipped)
deadline=$(( $(date +%s) + DEPLOY_WAIT_SECS ))
while :; do
  # If staging moved to a newer commit while we were waiting (another push
  # landed), abandon this cycle cleanly — containers are now rebuilding to the
  # new HEAD and will never reach our captured TARGET. The next timer tick
  # re-reads staging and processes the latest commit. No block, no
  # last-processed write, so the new HEAD isn't skipped. Self-supersedes rapid
  # pushes instead of stranding on an intermediate commit.
  CURRENT=$(as_foundry git -C "$REPO" ls-remote gitea refs/heads/staging 2>/dev/null | awk '{print $1}')
  if [ -n "$CURRENT" ] && [ "$CURRENT" != "$TARGET" ]; then
    log "staging advanced ${TARGET:0:12} -> ${CURRENT:0:12} mid-wait — abandoning this cycle; next tick will process the new HEAD"
    exit 0
  fi

  pending=""
  while read -r uuid label; do
    [ -z "$uuid" ] && continue
    if ! is_affected "$label"; then
      continue   # watch_paths didn't match — Coolify skipped this app
    fi
    img=$(docker ps --filter "name=$uuid" --format '{{.Image}}' | head -1)
    [ "${img#*:}" = "$TARGET" ] || pending="$pending $label"
  done < "$APPS_FILE"
  [ -z "$pending" ] && break
  if [ "$(date +%s)" -ge "$deadline" ]; then
    log "TIMEOUT waiting for staging deploys of:$pending — production NOT moved"
    echo "blocked $TARGET staging-deploy-timeout $(date -u +%FT%TZ)" > "$STATE_DIR/status"
    echo "$TARGET" > "$STATE_DIR/last-processed"
    exit 1
  fi
  sleep 15
done
log "staging containers ready for $TARGET"

# Sync e2e test files from gitea/staging so spec files always match the deployed containers.
# Without this, the local working tree (on the main branch) would run stale spec files
# against containers built from a newer staging commit.
as_foundry git -C "$REPO" fetch gitea >>"$LOG" 2>&1 || log "WARN: git fetch gitea failed — running with local spec files"
as_foundry git -C "$REPO" checkout gitea/staging -- e2e-suite/ packages/e2e/ >>"$LOG" 2>&1 \
  || log "WARN: could not sync e2e-suite from gitea/staging — running with local spec files"

# 2. Staging test suite.
# One-shot skip escape hatch: list spec basenames (e.g. mail.spec.ts) in
# /etc/foundry-promote/skip-specs-once to EXCLUDE them from THIS gate run only.
# Use when a gate-tested service is mid-migration/down for a known reason and
# its own tests would otherwise deadlock the fix that repairs it. The file is
# CONSUMED (deleted) after one run, so the next promotion is fully gated again.
SKIP_FILE=/etc/foundry-promote/skip-specs-once
SPEC_ARGS=""
if [ -s "$SKIP_FILE" ]; then
  skips=$(tr '\n' ' ' < "$SKIP_FILE")
  log "⚠ SKIP-ONCE ACTIVE for $TARGET — excluding specs: $skips (operator-set; one-shot, consuming now). Remaining specs still gate."
  for f in "$REPO"/e2e-suite/specs/*.spec.ts; do
    b=$(basename "$f"); skip=0
    for s in $skips; do [ "$b" = "$s" ] && skip=1; done
    [ "$skip" = 0 ] && SPEC_ARGS="$SPEC_ARGS specs/$b"
  done
  rm -f "$SKIP_FILE"
else
  # Run only the specs for affected apps (reduces gate time for single-app changes).
  # When packages/ changes, all apps are affected so all specs run.
  while read -r uuid label; do
    [ -z "$uuid" ] && continue
    is_affected "$label" || continue
    spec="${SPEC_FOR[$label]:-}"
    [ -n "$spec" ] && SPEC_ARGS="$SPEC_ARGS $spec"
  done < "$APPS_FILE"
  if [ -n "$SPEC_ARGS" ]; then
    log "affected specs:$SPEC_ARGS"
  else
    log "no gate specs for affected apps (build success is sufficient)"
  fi
fi

if [ -z "$SPEC_ARGS" ]; then
  log "staging tests GREEN (no specs to run)"
elif as_foundry "$REPO/e2e-suite/run-staging-tests.sh" $SPEC_ARGS >>"$LOG" 2>&1; then
  log "staging tests GREEN${SPEC_ARGS:+ (affected-only subset)}"
else
  log "staging tests RED — production NOT moved. Inspect $REPO/e2e-suite/test-results/ and $LOG"
  echo "blocked $TARGET tests-failed $(date -u +%FT%TZ)" > "$STATE_DIR/status"
  echo "$TARGET" > "$STATE_DIR/last-processed"
  exit 1
fi

# 3. Promote — fast-forward only
if as_foundry git -C "$REPO" push gitea "$TARGET:refs/heads/main" >>"$LOG" 2>&1; then
  log "PROMOTED $TARGET to main — Coolify deploys production"
else
  log "PROMOTION PUSH FAILED (non-fast-forward or auth) — inspect manually"
  echo "blocked $TARGET push-failed $(date -u +%FT%TZ)" > "$STATE_DIR/status"
  echo "$TARGET" > "$STATE_DIR/last-processed"
  exit 1
fi

# 4. Verify production actually reaches the commit (affected apps only).
# Coolify's gitea webhook auto-deploys, but its clone can fail transiently
# (gitea SSH blips), leaving production silently on the old build.
PROD_APPS=/etc/foundry-promote/production-apps
prod_deadline=$(( $(date +%s) + DEPLOY_WAIT_SECS ))
prod_stuck=""
if [ -f "$PROD_APPS" ]; then
  while read -r uuid label; do
    [ -z "$uuid" ] && continue
    is_affected "$label" || continue
    while :; do
      img=$(docker ps --filter "name=$uuid" --format '{{.Image}}' | head -1)
      [ "${img#*:}" = "$TARGET" ] && break
      if [ "$(date +%s)" -ge "$prod_deadline" ]; then prod_stuck="$prod_stuck $label"; break; fi
      sleep 15
    done
  done < "$PROD_APPS"
fi

if [ -n "$prod_stuck" ]; then
  log "PROMOTED but PRODUCTION DID NOT DEPLOY:$prod_stuck — likely a transient Coolify clone failure. Re-trigger from the control box: coolify-api GET /deploy?uuid=<app>"
  echo "needs-attention $TARGET prod-deploy-stuck:$prod_stuck $(date -u +%FT%TZ)" > "$STATE_DIR/status"
else
  log "production verified on $TARGET"
  echo "promoted $TARGET $(date -u +%FT%TZ)" > "$STATE_DIR/status"
fi

echo "$TARGET" > "$STATE_DIR/last-processed"
