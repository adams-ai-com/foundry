# Database
DATABASE_URL=postgresql://foundry:password@localhost:5432/foundry_mail

# API
API_PORT=3002
API_KEY=change-this-secret-key

# SMTP inbound (leave empty to disable inbound listener)
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
SMTP_HOST=0.0.0.0

# SMTP outbound relay (Mailgun example)
SMTP_RELAY_HOST=smtp.mailgun.org
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=postmaster@mg.yourdomain.com
SMTP_RELAY_PASS=your-mailgun-smtp-password

# DKIM (generate with: openssl genrsa -out dkim-private.pem 2048)
DKIM_PRIVATE_KEY_PATH=/etc/foundry-mail/dkim-private.pem
DKIM_SELECTOR=foundry

# Attachment storage
ATTACHMENTS_DIR=/var/lib/foundry-mail/attachments

# Default account domain (the domain this server handles)
MAIL_DOMAIN=yourdomain.com
